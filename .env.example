# Server configuration
PORT=3000

# MongoDB Atlas connection string
# Example:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/infinity-chat?retryWrites=true&w=majority&appName=<app-name>
MONGODB_URI=

# Upstash Redis configuration
# Copy these from Upstash Redis > REST API.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# JWT Secret
JWT_SECRET=replace_with_a_long_random_secret_for_your_app
